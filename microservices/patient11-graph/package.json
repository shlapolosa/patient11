{
  "name": "patient11-graph",
  "version": "2.0.0",
  "description": "GraphQL federation gateway (GraphQL Hive Gateway / Mesh v1) for Kubernetes services. Composes OpenAPI subgraphs from MESH_SOURCES into a federated supergraph.",
  "private": true,
  "type": "module",
  "scripts": {
    "compose": "mesh-compose -c mesh.config.ts -o ${CONFIG_DIR:-/app/config}/supergraph.graphql",
    "start": "./start.sh"
  },
  "dependencies": {
    "@graphql-hive/gateway": "2.8.3",
    "@graphql-mesh/compose-cli": "1.5.32",
    "@omnigraph/openapi": "0.109.52",
    "graphql": "16.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "graphql",
    "gateway",
    "federation",
    "hive",
    "graphql-mesh",
    "openapi",
    "kubernetes"
  ],
  "author": "Health Service IDP Platform",
  "license": "MIT"
}
